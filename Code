import React, { useState, useEffect, useRef } from 'react';
import { Send, BookOpen, Brain, Sparkles, RotateCcw, User, Bot, Lightbulb, Users, Eye, Zap, TrendingUp } from 'lucide-react';

const TeachingAgentChat = () => {
  const [messages, setMessages] = useState([]);
  const [input, setInput] = useState('');
  const [loading, setLoading] = useState(false);
  const [selectedTopic, setSelectedTopic] = useState('');
  const [learningLevel, setLearningLevel] = useState('intermediate');
  const [mode, setMode] = useState('single'); // 'single' or 'debate'
  const [visualizing, setVisualizing] = useState(false);
  const messagesEndRef = useRef(null);

  const topics = [
    { name: 'Machine Learning Basics', icon: '🤖', color: 'from-blue-500 to-cyan-500' },
    { name: 'Neural Networks', icon: '🧠', color: 'from-purple-500 to-pink-500' },
    { name: 'Python Programming', icon: '🐍', color: 'from-green-500 to-emerald-500' },
    { name: 'Data Structures', icon: '📊', color: 'from-orange-500 to-red-500' },
    { name: 'Statistics', icon: '📈', color: 'from-indigo-500 to-blue-500' },
    { name: 'Deep Learning', icon: '⚡', color: 'from-violet-500 to-purple-500' }
  ];

  const agents = [
    { 
      id: 'theorist', 
      name: 'Dr. Theory', 
      avatar: '👨‍🔬',
      color: 'from-blue-500 to-cyan-500',
      style: 'Focuses on theoretical foundations and mathematical rigor'
    },
    { 
      id: 'practitioner', 
      name: 'Prof. Practice', 
      avatar: '👩‍💻',
      color: 'from-green-500 to-emerald-500',
      style: 'Emphasizes practical applications and real-world examples'
    },
    { 
      id: 'simplifier', 
      name: 'Ms. Simple', 
      avatar: '👩‍🏫',
      color: 'from-pink-500 to-rose-500',
      style: 'Breaks down complex ideas using simple analogies'
    }
  ];

  useEffect(() => {
    messagesEndRef.current?.scrollIntoView({ behavior: 'smooth' });
  }, [messages]);

  const generateVisualization = async (concept) => {
    setVisualizing(true);
    
    try {
      const response = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 1000,
          messages: [{
            role: 'user',
            content: `Create a simple SVG visualization to explain: ${concept}. 
            
Return ONLY valid SVG code (starting with <svg>) with no explanation or markdown.
Make it educational, clear, and visually appealing with labels.
Size: 400x300, use vibrant colors.`
          }]
        })
      });

      const data = await response.json();
      let svgContent = data.content[0].text.trim();
      
      // Clean up the SVG content
      svgContent = svgContent.replace(/```svg\n?/g, '').replace(/```\n?/g, '').trim();
      
      const visualMessage = {
        role: 'assistant',
        type: 'visualization',
        content: concept,
        svg: svgContent,
        timestamp: new Date().toISOString()
      };
      
      setMessages(prev => [...prev, visualMessage]);
    } catch (error) {
      console.error('Visualization error:', error);
    } finally {
      setVisualizing(false);
    }
  };

  const handleMultiAgentDebate = async (question) => {
    const userMessage = {
      role: 'user',
      content: question,
      timestamp: new Date().toISOString()
    };

    setMessages(prev => [...prev, userMessage]);
    setInput('');
    setLoading(true);

    try {
      // Get responses from each agent
      for (const agent of agents) {
        const agentPrompt = `You are ${agent.name}, an AI teaching agent. ${agent.style}.

Topic: ${selectedTopic}
Student Level: ${learningLevel}
Student Question: ${question}

Provide a response from your unique perspective. Keep it concise (2-3 paragraphs).
${agent.id === 'theorist' ? 'Focus on theory and fundamentals.' : ''}
${agent.id === 'practitioner' ? 'Focus on practical applications.' : ''}
${agent.id === 'simplifier' ? 'Use simple language and analogies.' : ''}

Other agents will also respond, so focus on YOUR perspective.`;

        const response = await fetch('https://api.anthropic.com/v1/messages', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            model: 'claude-sonnet-4-20250514',
            max_tokens: 1000,
            messages: [{ role: 'user', content: agentPrompt }]
          })
        });

        const data = await response.json();
        const agentMessage = {
          role: 'assistant',
          agent: agent,
          content: data.content[0].text,
          timestamp: new Date().toISOString()
        };

        setMessages(prev => [...prev, agentMessage]);
        await new Promise(resolve => setTimeout(resolve, 500));
      }

      // Add synthesis
      const synthesisMessage = {
        role: 'assistant',
        type: 'synthesis',
        content: '💡 Each agent provided a different perspective! Try asking follow-up questions to dig deeper into any viewpoint.',
        timestamp: new Date().toISOString()
      };
      setMessages(prev => [...prev, synthesisMessage]);

    } catch (error) {
      console.error('Error:', error);
    } finally {
      setLoading(false);
    }
  };

  const handleSingleAgent = async (question) => {
    const userMessage = {
      role: 'user',
      content: question,
      timestamp: new Date().toISOString()
    };

    setMessages(prev => [...prev, userMessage]);
    setInput('');
    setLoading(true);

    try {
      const conversationHistory = messages
        .filter(msg => msg.role === 'user' || (msg.role === 'assistant' && !msg.agent))
        .map(msg => ({
          role: msg.role,
          content: msg.content
        }));

      const systemMessage = `You are an expert teaching assistant specializing in ${selectedTopic}.
Student level: ${learningLevel}

Guidelines:
- Provide clear, engaging explanations
- Use examples and analogies
- Break down complex concepts
- Be encouraging and supportive
- Suggest when a visual diagram might help`;

      const response = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 1000,
          system: systemMessage,
          messages: [
            ...conversationHistory,
            { role: 'user', content: question }
          ]
        })
      });

      const data = await response.json();
      const assistantMessage = {
        role: 'assistant',
        content: data.content[0].text,
        timestamp: new Date().toISOString()
      };

      setMessages(prev => [...prev, assistantMessage]);
    } catch (error) {
      console.error('Error:', error);
    } finally {
      setLoading(false);
    }
  };

  const handleSendMessage = () => {
    if (!input.trim()) return;
    
    if (mode === 'debate') {
      handleMultiAgentDebate(input);
    } else {
      handleSingleAgent(input);
    }
  };

  const resetChat = () => {
    setMessages([]);
    setInput('');
  };

  const startLearning = () => {
    if (!selectedTopic) return;
    
    const welcomeMessage = {
      role: 'assistant',
      content: mode === 'debate' 
        ? `🎭 Welcome to Multi-Agent Learning! Three expert teachers will help you understand ${selectedTopic} from different perspectives. Each brings a unique teaching style to enrich your learning experience.`
        : `👋 Hello! I'm excited to help you learn about ${selectedTopic} at the ${learningLevel} level. What would you like to explore first?`,
      timestamp: new Date().toISOString()
    };
    
    setMessages([welcomeMessage]);
  };

  const selectedTopicObj = topics.find(t => t.name === selectedTopic);

  return (
    <div className="min-h-screen bg-gradient-to-br from-slate-900 via-purple-900 to-slate-900 p-4 relative overflow-hidden">
      {/* Animated background elements */}
      <div className="absolute inset-0 overflow-hidden pointer-events-none">
        <div className="absolute top-20 left-10 w-72 h-72 bg-purple-500 rounded-full mix-blend-multiply filter blur-xl opacity-20 animate-pulse"></div>
        <div className="absolute top-40 right-10 w-72 h-72 bg-cyan-500 rounded-full mix-blend-multiply filter blur-xl opacity-20 animate-pulse" style={{animationDelay: '1s'}}></div>
        <div className="absolute -bottom-8 left-1/2 w-72 h-72 bg-pink-500 rounded-full mix-blend-multiply filter blur-xl opacity-20 animate-pulse" style={{animationDelay: '2s'}}></div>
      </div>

      <div className="max-w-7xl mx-auto relative z-10">
        {/* Header */}
        <div className="text-center mb-8">
          <div className="flex items-center justify-center gap-3 mb-4">
            <div className="relative">
              <Brain className="w-12 h-12 text-cyan-400 animate-pulse" />
              <Sparkles className="w-5 h-5 text-yellow-400 absolute -top-1 -right-1 animate-bounce" />
            </div>
            <h1 className="text-5xl font-bold bg-gradient-to-r from-cyan-400 via-purple-400 to-pink-400 bg-clip-text text-transparent">
              AI Teaching Nexus
            </h1>
          </div>
          <p className="text-cyan-300 text-lg">Multi-Agent Learning • Visual Explanations • Adaptive Intelligence</p>
        </div>

        <div className="grid lg:grid-cols-4 gap-6">
          {/* Configuration Panel */}
          <div className="lg:col-span-1">
            <div className="bg-white/10 backdrop-blur-lg rounded-3xl shadow-2xl p-6 space-y-6 border border-white/20">
              <div>
                <h3 className="text-xl font-bold text-white mb-4 flex items-center gap-2">
                  <Zap className="w-6 h-6 text-yellow-400" />
                  Learning Setup
                </h3>
                
                <div className="space-y-4">
                  {/* Mode Selection */}
                  <div>
                    <label className="block text-sm font-medium text-cyan-300 mb-3">
                      Teaching Mode
                    </label>
                    <div className="grid grid-cols-2 gap-2">
                      <button
                        onClick={() => setMode('single')}
                        className={`p-3 rounded-xl font-medium transition-all ${
                          mode === 'single'
                            ? 'bg-gradient-to-r from-cyan-500 to-blue-500 text-white shadow-lg scale-105'
                            : 'bg-white/10 text-gray-300 hover:bg-white/20'
                        }`}
                      >
                        <Bot className="w-5 h-5 mx-auto mb-1" />
                        <div className="text-xs">Single Agent</div>
                      </button>
                      <button
                        onClick={() => setMode('debate')}
                        className={`p-3 rounded-xl font-medium transition-all ${
                          mode === 'debate'
                            ? 'bg-gradient-to-r from-pink-500 to-purple-500 text-white shadow-lg scale-105'
                            : 'bg-white/10 text-gray-300 hover:bg-white/20'
                        }`}
                      >
                        <Users className="w-5 h-5 mx-auto mb-1" />
                        <div className="text-xs">Multi-Agent</div>
                      </button>
                    </div>
                  </div>

                  {/* Topic Selection */}
                  <div>
                    <label className="block text-sm font-medium text-cyan-300 mb-3">
                      Choose Topic
                    </label>
                    <div className="space-y-2">
                      {topics.map(topic => (
                        <button
                          key={topic.name}
                          onClick={() => setSelectedTopic(topic.name)}
                          className={`w-full text-left px-4 py-3 rounded-xl transition-all ${
                            selectedTopic === topic.name
                              ? `bg-gradient-to-r ${topic.color} text-white shadow-lg scale-105`
                              : 'bg-white/10 text-gray-300 hover:bg-white/20'
                          }`}
                        >
                          <div className="flex items-center gap-3">
                            <span className="text-2xl">{topic.icon}</span>
                            <span className="font-medium text-sm">{topic.name}</span>
                          </div>
                        </button>
                      ))}
                    </div>
                  </div>

                  {/* Level Selection */}
                  <div>
                    <label className="block text-sm font-medium text-cyan-300 mb-3">
                      Your Level
                    </label>
                    <div className="flex gap-2">
                      {['beginner', 'intermediate', 'advanced'].map(level => (
                        <button
                          key={level}
                          onClick={() => setLearningLevel(level)}
                          className={`flex-1 px-3 py-2 rounded-xl text-xs font-medium transition-all ${
                            learningLevel === level
                              ? 'bg-gradient-to-r from-green-500 to-emerald-500 text-white shadow-lg'
                              : 'bg-white/10 text-gray-300 hover:bg-white/20'
                          }`}
                        >
                          {level.charAt(0).toUpperCase() + level.slice(1)}
                        </button>
                      ))}
                    </div>
                  </div>

                  <button
                    onClick={startLearning}
                    disabled={!selectedTopic}
                    className="w-full bg-gradient-to-r from-cyan-500 via-purple-500 to-pink-500 text-white py-4 rounded-xl font-bold hover:shadow-2xl disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2 transition-all transform hover:scale-105"
                  >
                    <Sparkles className="w-5 h-5" />
                    Launch Learning
                  </button>

                  {messages.length > 0 && (
                    <button
                      onClick={resetChat}
                      className="w-full bg-white/10 text-white py-3 rounded-xl font-medium hover:bg-white/20 flex items-center justify-center gap-2 transition-all"
                    >
                      <RotateCcw className="w-4 h-4" />
                      Reset Session
                    </button>
                  )}
                </div>
              </div>

              {/* Agent Cards for Debate Mode */}
              {mode === 'debate' && (
                <div className="pt-6 border-t border-white/20">
                  <h4 className="font-bold text-white mb-3 flex items-center gap-2">
                    <Users className="w-5 h-5 text-pink-400" />
                    Your Teaching Team
                  </h4>
                  <div className="space-y-3">
                    {agents.map(agent => (
                      <div key={agent.id} className="bg-white/5 rounded-xl p-3 border border-white/10">
                        <div className="flex items-center gap-2 mb-1">
                          <span className="text-2xl">{agent.avatar}</span>
                          <span className="font-bold text-white text-sm">{agent.name}</span>
                        </div>
                        <p className="text-xs text-gray-400">{agent.style}</p>
                      </div>
                    ))}
                  </div>
                </div>
              )}
            </div>
          </div>

          {/* Chat Panel */}
          <div className="lg:col-span-3">
            <div className="bg-white/10 backdrop-blur-lg rounded-3xl shadow-2xl overflow-hidden h-[750px] flex flex-col border border-white/20">
              {/* Header */}
              <div className={`${selectedTopicObj ? `bg-gradient-to-r ${selectedTopicObj.color}` : 'bg-gradient-to-r from-purple-600 to-pink-600'} px-6 py-4 text-white`}>
                <div className="flex items-center justify-between">
                  <div>
                    <h2 className="text-2xl font-bold flex items-center gap-2">
                      {selectedTopicObj?.icon} {selectedTopic || 'Learning Session'}
                    </h2>
                    <p className="text-sm text-white/80 mt-1">
                      {mode === 'debate' ? '🎭 Multi-Agent Debate Mode' : '🤖 Single Agent Mode'} • {learningLevel} level
                    </p>
                  </div>
                  {messages.length > 0 && (
                    <button
                      onClick={() => {
                        const lastUserMessage = [...messages].reverse().find(m => m.role === 'user');
                        if (lastUserMessage) {
                          generateVisualization(lastUserMessage.content);
                        }
                      }}
                      disabled={visualizing}
                      className="bg-white/20 hover:bg-white/30 px-4 py-2 rounded-lg font-medium flex items-center gap-2 transition-all disabled:opacity-50"
                    >
                      <Eye className="w-4 h-4" />
                      Visualize
                    </button>
                  )}
                </div>
              </div>

              {/* Messages */}
              <div className="flex-1 overflow-y-auto p-6 space-y-4">
                {messages.length === 0 ? (
                  <div className="text-center py-20">
                    <div className="relative inline-block mb-6">
                      <Brain className="w-20 h-20 text-purple-400 animate-pulse" />
                      <Sparkles className="w-8 h-8 text-yellow-400 absolute -top-2 -right-2 animate-bounce" />
                    </div>
                    <p className="text-cyan-300 text-lg">Select a topic and mode to begin your learning adventure!</p>
                    <p className="text-gray-400 mt-2">Try multi-agent mode for diverse perspectives 🎭</p>
                  </div>
                ) : (
                  messages.map((msg, idx) => {
                    if (msg.type === 'visualization') {
                      return (
                        <div key={idx} className="flex justify-center">
                          <div className="bg-white/10 backdrop-blur-lg rounded-2xl p-6 border border-white/20 max-w-2xl">
                            <div className="flex items-center gap-2 mb-4">
                              <Eye className="w-5 h-5 text-cyan-400" />
                              <h4 className="font-bold text-white">Visual Explanation</h4>
                            </div>
                            <div className="bg-white rounded-xl p-4" dangerouslySetInnerHTML={{ __html: msg.svg }} />
                            <p className="text-gray-300 text-sm mt-3 italic">{msg.content}</p>
                          </div>
                        </div>
                      );
                    }

                    if (msg.type === 'synthesis') {
                      return (
                        <div key={idx} className="flex justify-center">
                          <div className="bg-gradient-to-r from-yellow-500/20 to-orange-500/20 backdrop-blur-lg rounded-2xl px-6 py-4 border border-yellow-500/30 max-w-2xl">
                            <p className="text-yellow-100 text-center font-medium">{msg.content}</p>
                          </div>
                        </div>
                      );
                    }

                    return (
                      <div
                        key={idx}
